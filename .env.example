# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored and never committed.

# Google Gemini API key — SERVER-ONLY (no NEXT_PUBLIC_ prefix), read only in
# app/api/ai/route.ts so it never ships in the browser bundle.
# Get a free key at https://aistudio.google.com/apikey
# On Vercel: add this as a normal (non-public) Environment Variable.
GEMINI_API_KEY=your_key_here

# Novus (Pendo) analytics app ID — public by design (loads in the browser).
# Leave blank to disable the analytics script. Set after connecting your repo in Novus.
NEXT_PUBLIC_NOVUS_APP_ID=
